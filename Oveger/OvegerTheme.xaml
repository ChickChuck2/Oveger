<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================ -->
    <!-- OVEGER DESIGN SYSTEM — Glass Dark Theme          -->
    <!-- Accent: Violet #7C3AED  |  Indigo #4F46E5        -->
    <!-- ================================================ -->

    <!-- ─── BRUSHES ──────────────────────────────────── -->
    <SolidColorBrush x:Key="GlassBg"          Color="#0D0D1A" />
    <SolidColorBrush x:Key="GlassBorder"      Color="#FFFFFF" />
    <SolidColorBrush x:Key="AccentPrimary"    Color="#7C3AED" />
    <SolidColorBrush x:Key="AccentSecondary"  Color="#4F46E5" />
    <SolidColorBrush x:Key="AccentGlow"       Color="#A78BFA" />
    <SolidColorBrush x:Key="TextPrimary"      Color="#F1F5F9" />
    <SolidColorBrush x:Key="TextMuted"        Color="#94A3B8" />
    <SolidColorBrush x:Key="DangerBrush"      Color="#EF4444" />
    <SolidColorBrush x:Key="SuccessBrush"     Color="#10B981" />
    <SolidColorBrush x:Key="SurfaceBrush"     Color="#1E1B2E" />
    <SolidColorBrush x:Key="SurfaceHover"     Color="#2D2A42" />

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#7C3AED" Offset="0"/>
        <GradientStop Color="#4F46E5" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientHover" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#9D6AF5" Offset="0"/>
        <GradientStop Color="#6B63F0" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EF4444" Offset="0"/>
        <GradientStop Color="#B91C1C" Offset="1"/>
    </LinearGradientBrush>

    <!-- ─── EFFECTS ──────────────────────────────────── -->
    <DropShadowEffect x:Key="GlowEffect"
                      Color="#7C3AED"
                      BlurRadius="24"
                      ShadowDepth="0"
                      Opacity="0.6"/>

    <DropShadowEffect x:Key="CardShadow"
                      Color="#000000"
                      BlurRadius="20"
                      ShadowDepth="4"
                      Opacity="0.5"/>

    <DropShadowEffect x:Key="SubtleShadow"
                      Color="#7C3AED"
                      BlurRadius="14"
                      ShadowDepth="0"
                      Opacity="0.25"/>

    <!-- ─── ACCENT BUTTON ─────────────────────────────── -->
    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable, Segoe UI, sans-serif"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="10"
                            Background="{StaticResource AccentGradient}"
                            Effect="{StaticResource SubtleShadow}"
                            Padding="16,8"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentGradientHover}"/>
                            <Setter TargetName="Root" Property="Effect"     Value="{StaticResource GlowEffect}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── DANGER BUTTON ────────────────────────────── -->
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable, Segoe UI, sans-serif"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="10"
                            Background="{StaticResource DangerGradient}"
                            Padding="16,8"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── GLASS CARD ──────────────────────────────── -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#1A1730" Opacity="0.72"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.10"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="16"/>
        <Setter Property="Effect"          Value="{StaticResource CardShadow}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ─── DARK INPUT ───────────────────────────────── -->
    <Style x:Key="DarkInput" TargetType="TextBox">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#12101E" Opacity="0.8"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
        <Setter Property="CaretBrush"       Value="{StaticResource AccentGlow}"/>
        <Setter Property="FontFamily"       Value="Segoe UI Variable, Segoe UI, sans-serif"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="Padding"          Value="10,6"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.12"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      VerticalAlignment="Center"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentGlow}"/>
                            <Setter TargetName="Root" Property="Effect"      Value="{StaticResource SubtleShadow}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── DARK COMBOBOX ────────────────────────────── -->
    <Style x:Key="DarkComboBox" TargetType="ComboBox">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#12101E" Opacity="0.9"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily"       Value="Segoe UI Variable, Segoe UI, sans-serif"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="Padding"          Value="10,6"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.12"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Grid Margin="10,6,4,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="ContentSite"
                                                  Grid.Column="0"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="▾"
                                           Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Center"
                                           FontSize="10"/>
                            </Grid>
                        </Border>
                        <Popup x:Name="Popup" Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False">
                            <Border CornerRadius="8" Background="#1E1B2E"
                                    BorderBrush="#7C3AED" BorderThickness="1"
                                    Effect="{StaticResource CardShadow}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    MinWidth="{TemplateBinding ActualWidth}">
                                <ScrollViewer>
                                    <StackPanel IsItemsHost="True"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentGlow}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="Padding"     Value="10,6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="ItemBorder"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#2D2A42"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#3B1F7A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── PILL GROUP TAB ───────────────────────────── -->
    <Style x:Key="PillTab" TargetType="Button">
        <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable, Segoe UI, sans-serif"/>
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="FontWeight"  Value="Medium"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Margin"      Value="4,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="20"
                            Background="#1E1B2E"
                            BorderBrush="#FFFFFF"
                            BorderThickness="0"
                            Padding="14,5">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#2D2A42"/>
                            <Setter TargetName="Root" Property="Effect"     Value="{StaticResource SubtleShadow}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentGradient}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── GHOST BUTTON (context menu item) ─────────── -->
    <Style x:Key="ContextMenuBtn" TargetType="Button">
        <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable, Segoe UI, sans-serif"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="Transparent"
                            CornerRadius="8"
                            Padding="12,7"
                            Margin="4,1"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#2D2A42"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#3B1F7A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── DANGER CONTEXT MENU ITEM ─────────────────── -->
    <Style x:Key="ContextMenuBtnDanger" TargetType="Button" BasedOn="{StaticResource ContextMenuBtn}">
        <Setter Property="Foreground" Value="#FCA5A5"/>
    </Style>

    <!-- ─── SCROLLBAR ────────────────────────────────── -->
    <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
        <Setter Property="Width"      Value="4"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="2"
                                                    Background="#7C3AED"
                                                    Opacity="0.5"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlimScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ScrollContentPresenter Grid.Column="0"/>
                        <ScrollBar Grid.Column="1"
                                   x:Name="PART_VerticalScrollBar"
                                   Style="{StaticResource SlimScrollBar}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── EXPANDER (Group header) ──────────────────── -->
    <Style x:Key="GlassExpander" TargetType="Expander">
        <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily"  Value="Segoe UI Variable, Segoe UI, sans-serif"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <StackPanel>

                        <!-- Header toggle button
                             Key fix: Content="{TemplateBinding Header}" passes the group name
                             into the ToggleButton so it can be rendered by ContentPresenter inside. -->
                        <ToggleButton x:Name="ExpanderToggle"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay,
                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                      Content="{TemplateBinding Header}"
                                      Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="HeaderBg"
                                            CornerRadius="10"
                                            Margin="0,3"
                                            Padding="14,9"
                                            BorderThickness="1"
                                            SnapsToDevicePixels="True">
                                        <Border.Background>
                                            <SolidColorBrush Color="#12101E" Opacity="0.85"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#FFFFFF" Opacity="0.07"/>
                                        </Border.BorderBrush>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="28"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Colored dot accent -->
                                            <Border Grid.Column="0"
                                                    Width="8" Height="8"
                                                    CornerRadius="4"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#7C3AED" Offset="0"/>
                                                        <GradientStop Color="#4F46E5" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <!-- Group name (passed via Content → ContentPresenter) -->
                                            <ContentPresenter Grid.Column="1"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="#A78BFA"
                                                              TextElement.FontSize="13"
                                                              TextElement.FontWeight="SemiBold"/>

                                            <!-- Arrow indicator -->
                                            <TextBlock x:Name="Arrow"
                                                       Grid.Column="2"
                                                       Text="▾"
                                                       Foreground="#64748B"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Collapsed state: arrow points right -->
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter TargetName="Arrow" Property="Text" Value="▸"/>
                                        </Trigger>
                                        <!-- Hover: subtle highlight -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="HeaderBg" Property="BorderBrush">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#7C3AED" Opacity="0.35"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Expandable content area -->
                        <ContentPresenter x:Name="ExpanderContent"
                                          Margin="0,2,0,6"
                                          Visibility="Collapsed"/>
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpanderContent" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
