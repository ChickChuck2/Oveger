<Window x:Class="Oveger.XAMLS.ChangePathForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Oveger.XAMLS"
        mc:Ignorable="d"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Initialized="Window_Initialized"
        Title="Mudar Caminho — Oveger"
        Height="260" Width="500"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:ChangePathForm.MyCommand}" Executed="MyCommandExecuted"/>
    </Window.CommandBindings>

    <Border CornerRadius="16" Padding="28,24" SnapsToDevicePixels="True">
        <Border.Background>
            <SolidColorBrush Color="#0F0D1F" Opacity="0.97"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#FFFFFF" Opacity="0.09"/>
        </Border.BorderBrush>
        <Border.BorderThickness>1</Border.BorderThickness>
        <Border.Effect>
            <DropShadowEffect Color="#7C3AED" BlurRadius="30" ShadowDepth="0" Opacity="0.22"/>
        </Border.Effect>

        <StackPanel>
            <!-- Title -->
            <TextBlock Text="Mudar caminho do arquivo"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0,0,0,20"/>

            <!-- Old path (readonly) -->
            <TextBlock Text="CAMINHO ATUAL" FontSize="10" FontWeight="SemiBold"
                       Foreground="#64748B" Margin="0,0,0,6"/>
            <TextBox x:Name="oldPathBox"
                     Style="{StaticResource DarkInput}"
                     Height="36"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Foreground="#64748B"
                     Margin="0,0,0,16"/>

            <!-- New path -->
            <TextBlock Text="NOVO CAMINHO" FontSize="10" FontWeight="SemiBold"
                       Foreground="#64748B" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="newPathBox"
                         Grid.Column="0"
                         Style="{StaticResource DarkInput}"
                         Height="36"
                         VerticalContentAlignment="Center"/>
                <Button x:Name="choosePath"
                        Grid.Column="2"
                        Width="36" Height="36"
                        ToolTip="Escolher arquivo"
                        Click="ChoosePath_Click"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root" CornerRadius="8"
                                    BorderThickness="1">
                                <Border.Background>
                                    <SolidColorBrush Color="#1A1730" Opacity="0.8"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#FFFFFF" Opacity="0.12"/>
                                </Border.BorderBrush>
                                <TextBlock Text="📂" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#7C3AED"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Confirm -->
            <Button x:Name="confirmbutton"
                    Content="Confirmar"
                    Style="{StaticResource AccentButton}"
                    Height="40"
                    IsDefault="True"/>
        </StackPanel>
    </Border>
</Window>
