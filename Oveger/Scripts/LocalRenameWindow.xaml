<Window x:Class="Oveger.XAMLS.LocalRenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Oveger.XAMLS"
        mc:Ignorable="d"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Initialized="Window_Initialized"
        Title="Renomear — Oveger"
        Height="170" Width="360"
        WindowStartupLocation="CenterScreen">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:LocalRenameWindow.MyCommand}" Executed="MyCommandExecuted"/>
    </Window.CommandBindings>

    <Border CornerRadius="16" Padding="24,20" SnapsToDevicePixels="True">
        <Border.Background>
            <SolidColorBrush Color="#0F0D1F" Opacity="0.97"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#FFFFFF" Opacity="0.09"/>
        </Border.BorderBrush>
        <Border.BorderThickness>1</Border.BorderThickness>
        <Border.Effect>
            <DropShadowEffect Color="#7C3AED" BlurRadius="30" ShadowDepth="0" Opacity="0.22"/>
        </Border.Effect>

        <StackPanel>
            <TextBlock Text="Renomear item"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0,0,0,14"/>
            <TextBox x:Name="renamedbox"
                     Style="{StaticResource DarkInput}"
                     Height="38"
                     VerticalContentAlignment="Center"
                     Margin="0,0,0,16"/>
            <Button x:Name="ConfirmButton"
                    Content="Confirmar"
                    Style="{StaticResource AccentButton}"
                    Height="38"
                    IsDefault="True"/>
        </StackPanel>
    </Border>
</Window>
