<Window x:Class="Oveger.XAMLS.RightButtonClick"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Oveger.XAMLS"
        mc:Ignorable="d"
        Title="RightButtonClick"
        Height="Auto" Width="210"
        WindowStyle="None"
        Foreground="White"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Deactivated="Window_Deactivated"
        SizeToContent="Height"
        Topmost="True"
        Background="Transparent">

    <!-- Fade-in on load -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootCard"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.18"/>
                    <ThicknessAnimation Storyboard.TargetName="RootCard"
                                        Storyboard.TargetProperty="Margin"
                                        From="0,8,0,0" To="0,0,0,0"
                                        Duration="0:0:0.18"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- Glass card -->
    <Border x:Name="RootCard" CornerRadius="14" Opacity="0"
            Padding="6,8" Margin="0"
            SnapsToDevicePixels="True">
        <Border.Background>
            <SolidColorBrush Color="#0F0D1F" Opacity="0.95"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#FFFFFF" Opacity="0.10"/>
        </Border.BorderBrush>
        <Border.BorderThickness>1</Border.BorderThickness>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="6" Opacity="0.7"/>
        </Border.Effect>

        <StackPanel>
            <!-- Section: Open actions -->
            <Button x:Name="open"          Style="{StaticResource ContextMenuBtn}" Width="198">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="  ▶  " Foreground="#A78BFA" VerticalAlignment="Center"/>
                    <TextBlock Text="Abrir" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button x:Name="openfolderpath" Style="{StaticResource ContextMenuBtn}" Width="198">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="  📂 " Foreground="#94A3B8" VerticalAlignment="Center"/>
                    <TextBlock Text="Abrir local do arquivo" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button x:Name="property"       Style="{StaticResource ContextMenuBtn}" Width="198">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="  ℹ  " Foreground="#94A3B8" VerticalAlignment="Center"/>
                    <TextBlock Text="Propriedades" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Separator -->
            <Border Height="1" Margin="12,4" Opacity="0.12">
                <Border.Background>
                    <SolidColorBrush Color="#FFFFFF"/>
                </Border.Background>
            </Border>

            <!-- Section: Edit actions -->
            <Button x:Name="rename"     Style="{StaticResource ContextMenuBtn}" Width="198">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="  ✏  " Foreground="#94A3B8" VerticalAlignment="Center"/>
                    <TextBlock Text="Renomear" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button x:Name="changepath" Style="{StaticResource ContextMenuBtn}" Width="198">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="  🔗 " Foreground="#94A3B8" VerticalAlignment="Center"/>
                    <TextBlock Text="Mudar caminho" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button x:Name="addgroup"   Style="{StaticResource ContextMenuBtn}" Width="198">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="  🏷  " Foreground="#94A3B8" VerticalAlignment="Center"/>
                    <TextBlock Text="Adicionar a Grupo" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Separator -->
            <Border Height="1" Margin="12,4" Opacity="0.12">
                <Border.Background>
                    <SolidColorBrush Color="#FFFFFF"/>
                </Border.Background>
            </Border>

            <!-- Section: Danger -->
            <Button x:Name="DeleteinProgram" Style="{StaticResource ContextMenuBtnDanger}" Width="198">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="  ✕  " Foreground="#FCA5A5" VerticalAlignment="Center"/>
                    <TextBlock Text="Remover do programa" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button x:Name="DeleteButton" Style="{StaticResource ContextMenuBtnDanger}" Width="198">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="  🗑  " Foreground="#FCA5A5" VerticalAlignment="Center"/>
                    <TextBlock Text="Excluir arquivo" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</Window>
