<Window x:Class="Oveger.XAMLS.Helpandshortcut"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Oveger.XAMLS"
        mc:Ignorable="d"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Title="Atalhos — Oveger"
        Height="360" Width="480"
        WindowStartupLocation="CenterScreen"
        Initialized="Window_Initialized">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:Helpandshortcut.MyCommand}" Executed="MyCommandExecuted"/>
    </Window.CommandBindings>

    <Border CornerRadius="20" Padding="32" SnapsToDevicePixels="True">
        <Border.Background>
            <SolidColorBrush Color="#0F0D1F" Opacity="0.96"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#FFFFFF" Opacity="0.09"/>
        </Border.BorderBrush>
        <Border.BorderThickness>1</Border.BorderThickness>
        <Border.Effect>
            <DropShadowEffect Color="#7C3AED" BlurRadius="40" ShadowDepth="0" Opacity="0.25"/>
        </Border.Effect>

        <StackPanel>
            <!-- Title row -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7C3AED" Offset="0"/>
                            <GradientStop Color="#4F46E5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="⌨" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Configurar Atalho Global"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Current hotkey info -->
            <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,20">
                <Border.Background>
                    <SolidColorBrush Color="#1A1730" Opacity="0.8"/>
                </Border.Background>
                <TextBlock x:Name="infokey"
                           Text="Atalho atual: ..."
                           FontSize="13"
                           Foreground="#A78BFA"
                           FontWeight="Medium"/>
            </Border>

            <!-- Fields row -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="MOD KEY 1" FontSize="11" Foreground="#64748B"
                               Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <ComboBox x:Name="mod1box" Style="{StaticResource DarkComboBox}" Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="MOD KEY 2" FontSize="11" Foreground="#64748B"
                               Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <ComboBox x:Name="mod2box" Style="{StaticResource DarkComboBox}" Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="TECLA" FontSize="11" Foreground="#64748B"
                               Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <ComboBox x:Name="keybox" Style="{StaticResource DarkComboBox}" Height="36"/>
                </StackPanel>
            </Grid>

            <!-- Confirm + Close -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="Confirmar Atalho"
                        Style="{StaticResource AccentButton}"
                        Height="40"
                        Click="Button_Click"/>
                <Button Grid.Column="2"
                        Content="Fechar"
                        Height="40"
                        Padding="20,0"
                        Foreground="#94A3B8"
                        FontFamily="Segoe UI Variable, Segoe UI"
                        FontSize="13"
                        Click="CloseButton_Click"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root" CornerRadius="10" Padding="20,8"
                                    BorderThickness="1">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#FFFFFF" Opacity="0.12"/>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <SolidColorBrush Color="#1A1730" Opacity="0.6"/>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextElement.Foreground="#94A3B8"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.75"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>
